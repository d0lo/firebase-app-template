{
  "name": "firebase-app-template",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Opinionated Firebase + web app starter with CI/CD and an agent setup runbook.",
  "type": "module",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "build": "npm run build --workspace app",
    "dev": "npm run dev --workspace app",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "firebase emulators:exec --only firestore --project demo-template --config firebase/firebase.json \"vitest run -c vitest.integration.config.ts\"",
    "e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{vue,json,yml,yaml,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.48.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "firebase-tools": "^15.22.4",
    "globals": "^17.7.0",
    "husky": "^9.1.6",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
