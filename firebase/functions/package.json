{
  "name": "functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "description": "Cloud Functions (bundled with esbuild before deploy).",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --external:firebase-admin --external:firebase-functions --outfile=lib/index.js",
    "typecheck": "tsc --noEmit",
    "serve": "firebase emulators:start --only functions,firestore,auth",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
