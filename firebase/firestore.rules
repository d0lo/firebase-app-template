rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Example: per-user documents ────────────────────────────────────────────
    // A signed-in user may read/write only their own doc. Adjust to your model.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Example: server-only collection ────────────────────────────────────────
    // World-readable, but only Cloud Functions (Admin SDK, which bypasses rules)
    // may write. Use this for authoritative state a client must not forge.
    match /server/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny — anything not matched above is locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
