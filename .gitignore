# dependencies
node_modules/

# builds
dist/
build/
*.tsbuildinfo
# functions bundle output (scoped path — NOT a bare `lib/`, which would also
# swallow real source dirs like app/src/lib)
/firebase/functions/lib/

# firebase
.firebase/
*-debug.log
.firebaserc

# env / secrets
.env
.env.*
!.env.example
*serviceAccount*.json
*service-account*.json

# editor / os
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json

# test
coverage/

# hosting build output (app/dist is copied here before deploy)
firebase/public/

# terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/terraform.tfvars
terraform/crash.log

# playwright
test-results/
playwright-report/
blob-report/
.playwright/
